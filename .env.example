# MongoDB connection string (Atlas recommended for Vercel)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/mermaid?retryWrites=true&w=majority

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-strong-random-secret
NEXTAUTH_URL=http://localhost:3000

# Optional Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (optional — used by password reset).
# If unset, reset links are logged to the server console for local dev.
# Get a key at https://resend.com — free tier covers low-volume transactional mail.
RESEND_API_KEY=
EMAIL_FROM="Mermaid Studio <noreply@your-domain.com>"
